import super::shared::*;

fn main(
    BID_VERIFIER: BidVerifier,
    Truth: AuctionStateTruth,
    bid: Bid,
) -> Output {
    let old_bid = inline if Truth.state.winning_bid.amount == 0 {
        nil
    } else {
        Truth.state.winning_bid
    };

    assert BID_VERIFIER(old_bid, bid);

    Output {
        new_truth: Truth,
        conditions: [],
    }
}
